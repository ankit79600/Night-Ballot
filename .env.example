# Night Ballot — environment variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# 32-byte organizer secret key (hex, 64 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORGANIZER_KEY=

# Network to deploy/interact with: preprod | preview
NETWORK=preprod

# Wallet seed phrase (for deployment)
WALLET_SEED=

# Contract address (filled after first deployment)
CONTRACT_ADDRESS=

# Proof server URL (default: local Docker)
PROOF_SERVER_URL=http://localhost:6300
